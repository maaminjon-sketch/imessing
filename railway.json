{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --include=dev && npm run build"
  },
  "deploy": {
    "startCommand": "npm run db:push && npm start",
    "healthcheckPath": "/api/trpc/ping",
    "restartPolicyType": "ON_FAILURE"
  }
}